<nav-bar/>
<view class="breadcrumb">
  <navigator url="/pages/index/index" open-type="switchTab" class="link">首页</navigator>
  <text> > </text>
  <text class="current">巡防勤务</text>
</view>

<view class="search-bar">
  <input placeholder="🔍  搜索勤务..." bindinput="onSearch"/>
</view>

<view class="page-container list-page">
  <view class="page-title">
    <view class="h1">📋 巡防勤务</view>
    <view class="meta">
      <view class="tag">8篇</view>
      <view class="tag">大型活动 · 群体事件</view>
    </view>
  </view>

  <view wx:for="{{sections}}" wx:key="*this">
    <view class="list-section-title">{{item.name}}</view>
    <navigator wx:for="{{item.items}}" wx:key="id"
      url="/pages/qinwu/detail/detail?id={{item.id}}"
      class="list-item">
      <view class="item-title">{{item.icon}} {{item.title}}</view>
      <view class="item-desc">{{item.desc}}</view>
    </navigator>
  </view>
</view>
